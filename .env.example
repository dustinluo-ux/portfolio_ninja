# portfolio_ninja — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Anthropic API (required for managed_builder.py cloud builds)
# Skip if set as a Windows user environment variable.
ANTHROPIC_API_KEY=sk-ant-...

# Session budget guard (optional — halts pipeline before breaching)
# BUDGET_USD=10.00

# Managed Builder — set once via: python scripts/managed_builder.py --setup
# MANAGED_BUILDER_ENVIRONMENT_ID=env_...
# MANAGED_BUILDER_AGENT_ID=agt_...
# MANAGED_BUILDER_AGENT_VERSION=1

# Data source credentials (fill when data adapters are implemented)
# DATA_API_KEY=your_data_api_key_here

# Execution adapter credentials (fill when live mode is activated)
# BROKER_API_KEY=your_broker_api_key_here
# BROKER_API_SECRET=your_broker_api_secret_here

# Run mode (backtest | paper | live) — default: backtest
# RUN_MODE=backtest
